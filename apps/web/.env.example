# NEXUS Frontend Environment Variables
# For local development, copy to .env.local
# For production, set in your hosting platform

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Application Settings
NEXT_PUBLIC_APP_NAME=NEXUS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# InsForge Configuration
NEXT_PUBLIC_INSFORGE_URL=https://aev8u7h7.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-insforge-anon-key

# ==========================================
# PRODUCTION URLS (set in deployment platform)
# ==========================================
# For Vercel/Netlify: Set NEXT_PUBLIC_API_URL to your API URL
# For Railway/Render: Set to Railway/Render API URL
# For AWS: Set to your API Gateway/Lambda URL