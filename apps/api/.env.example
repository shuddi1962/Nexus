# NEXUS Backend Environment Variables
# For local development, copy to .env
# For production, set in your hosting platform

# ==========================================
# INSFORGE DATABASE (Required)
# ==========================================
INSFORGE_URL=https://aev8u7h7.us-east.insforge.app
INSFORGE_API_KEY=your-insforge-api-key
INSFORGE_DB_NAME=nexus

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# ==========================================
# AUTHENTICATION (Required - Generate secure random values)
# ==========================================
JWT_SECRET=64-character-random-hex-string-for-jwt
JWT_REFRESH_SECRET=64-character-random-hex-string-for-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# ENCRYPTION (Required - For API keys vault)
# ==========================================
ENCRYPTION_KEY=32-byte-hex-string-for-aes-encryption
ENCRYPTION_IV_LENGTH=16

# ==========================================
# REDIS (Required for Railway/Render/AWS)
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# FRONTEND URL (Required)
# ==========================================
FRONTEND_URL=http://localhost:3000

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================
SYSTEM_SMTP_HOST=your-smtp-host
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=your-smtp-username
SYSTEM_SMTP_PASS=your-smtp-password
SYSTEM_FROM_EMAIL=noreply@nexus.app

# ==========================================
# PRODUCTION URLS (Set in deployment platform)
# ==========================================
# For Railway/Render: FRONTEND_URL will be your Railway/Render frontend URL
# For AWS: FRONTEND_URL will be your CloudFront/S3 URL
# For Vercel/Netlify: FRONTEND_URL will be your Vercel/Netlify URL

# ==========================================
# OAUTH CONFIGURATION (Optional)
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/oauth/google/callback

LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3001/auth/oauth/linkedin/callback

# ==========================================
# HEALTH CHECKS
# ==========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/api/health